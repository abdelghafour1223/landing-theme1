<!DOCTYPE html>
<html class="js" lang="ar" dir="rtl" data-heading-scale="100" data-body-scale="100" data-heading-letter-spacing="0" data-body-letter-spacing="0" data-button-text-case="" data-button-radius="40" data-apply-button-radius-to-all="true" style="--font-body: 'Inter', sans-serif; --font-heading: 'Inter', sans-serif; --letter-spacing-heading: 0px; --letter-spacing-body: 0px; --font-weight-regular: 400; --font-weight-semibold: 600; --font-weight-bold: 700; --min-font-size-h1: 32px; --max-font-size-h1: 48px; --font-size-h1: calc(32px + (48 - 32) * ((100vw - 375px) / (1440 - 375))); --min-font-size-h2: 28px; --max-font-size-h2: 40px; --font-size-h2: calc(28px + (40 - 28) * ((100vw - 375px) / (1440 - 375))); --min-font-size-h3: 24px; --max-font-size-h3: 32px; --font-size-h3: calc(24px + (32 - 24) * ((100vw - 375px) / (1440 - 375))); --min-font-size-h4: 20px; --max-font-size-h4: 24px; --font-size-h4: calc(20px + (24 - 20) * ((100vw - 375px) / (1440 - 375))); --min-font-size-h5: 18px; --max-font-size-h5: 20px; --font-size-h5: calc(18px + (20 - 18) * ((100vw - 375px) / (1440 - 375))); --min-font-size-h6: 16px; --max-font-size-h6: 18px; --font-size-h6: calc(16px + (18 - 16) * ((100vw - 375px) / (1440 - 375))); --font-size-body-large: 18px; --font-size-body: 16px; --font-size-body-small: 14px; --font-size-caption: 12px; --button-text-transform: uppercase; --color-text: #000000; --color-main-accent: #ef4a65; --color-light-accent: #ffeaee;">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="theme-color" content="">
  <link rel="canonical" href="{{ canonical_url }}">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  {% render 'meta-tags' %}

  <!-- Standard Shopify Dawn Core Scripts -->
  <script src="{{ 'constants.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'pubsub.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'global.js' | asset_url }}" defer="defer"></script>

  <!-- Base Custom Font & Shopify styles -->
  {{ 'typography-combined.css' | asset_url | stylesheet_tag }}
  {{ 'base.css' | asset_url | stylesheet_tag }}
  {{ 'button-styling.css' | asset_url | stylesheet_tag }}

  <!-- jQuery & Slick (For dynamic gallery/carousels) -->
  <script src="{{ 'jquery.min.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'slick.min.js' | asset_url }}" defer="defer"></script>
  {{ 'slick.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'custom.js' | asset_url }}" defer="defer"></script>
  {{ 'custom.css' | asset_url | stylesheet_tag }}

  <!-- Localized Dynamic Clean Styles -->
  {{ 'theme-variables.css' | asset_url | stylesheet_tag }}
  {{ 'enhanced-buttons.css' | asset_url | stylesheet_tag }}
  {{ 'components.css' | asset_url | stylesheet_tag }}

  <!-- Dynamic Shopify header hooks -->
  {{ content_for_header }}
</head>

<body class="color-1 h1-heading-font h2-heading-font typography-settings-applied global-colors-applied">
  {% section 'announcement-bar' %}

  <a class="skip-to-content-link button visually-hidden button-box-shadow intensity-5 button-gradient-effect gradient-shine-enabled" href="#MainContent">
    Skip to content
  </a>

  <!-- Dynamic Content for Layout -->
  <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  <!-- Modularized JS Resources -->
  <script src="{{ 'theme.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'faq-accordion.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'guarantee-scroll.js' | asset_url }}" defer="defer"></script>

  <!-- Video IntersectionObserver script -->
  <script>
  document.addEventListener('DOMContentLoaded', function() {
    const videoObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        const video = entry.target;
        if (entry.isIntersecting) {
          video.play().catch(() => {});
        } else {
          video.pause();
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.inline-video-container video').forEach(video => {
      videoObserver.observe(video);
    });
  });
  </script>
</body>
</html>
