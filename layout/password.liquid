<!doctype html>
<html class="no-js full-height" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">
    <link rel="canonical" href="{{ canonical_url }}">

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>{{ shop.name }}</title>
    <meta name="description" content="{{ page_description | escape }}">

    {% render 'meta-tags' %}
    {{ content_for_header }}

    {{ 'base.css' | asset_url | stylesheet_tag }}

    <style>
      :root {
        --color-bg: #fafaf9;
        --color-text: #000000;
        --color-accent: #ef4a65;
        --color-accent-light: #ffeaee;
        --font-body: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      }

      body.password {
        margin: 0;
        padding: 0;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        font-family: var(--font-body);
        background: var(--color-bg);
        color: var(--color-text);
      }

      .password-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 20px 40px;
        border-bottom: 1px solid rgba(0,0,0,0.08);
      }

      .password-header__heading {
        font-size: 20px;
        font-weight: 700;
        margin: 0;
        text-decoration: none;
        color: var(--color-text);
      }

      .password-header__logo {
        max-width: 120px;
        height: auto;
      }

      .password-link {
        font-size: 14px;
        color: var(--color-text);
        text-decoration: underline;
        cursor: pointer;
        background: none;
        border: none;
        font-family: inherit;
        display: inline-flex;
        align-items: center;
        gap: 6px;
      }

      .password-main {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 20px;
      }

      .password-main__inner {
        text-align: center;
        max-width: 500px;
        width: 100%;
      }

      .password-main__inner h1 {
        font-size: 32px;
        font-weight: 700;
        margin: 0 0 12px;
      }

      .password-main__inner p {
        font-size: 16px;
        color: #666;
        margin: 0 0 20px;
        line-height: 1.6;
      }

      .password-content {
        font-size: 16px;
        color: #666;
        margin-bottom: 24px;
      }

      /* Password Modal */
      .password-modal {
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0,0,0,0.5);
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
      }

      .password-modal[hidden] { display: none; }

      .password-modal__box {
        background: #fff;
        border-radius: 12px;
        padding: 40px;
        max-width: 420px;
        width: 100%;
        position: relative;
        box-shadow: 0 20px 60px rgba(0,0,0,0.15);
      }

      .password-modal__box h2 {
        font-size: 22px;
        margin: 0 0 20px;
        font-weight: 700;
      }

      .password-modal__close {
        position: absolute;
        top: 16px;
        right: 16px;
        background: none;
        border: none;
        cursor: pointer;
        font-size: 24px;
        color: #666;
        line-height: 1;
      }

      .password-form .field {
        margin-bottom: 16px;
      }

      .password-form input[type="password"] {
        width: 100%;
        padding: 12px 16px;
        border: 1px solid #ddd;
        border-radius: 8px;
        font-size: 16px;
        font-family: inherit;
        box-sizing: border-box;
        transition: border-color 0.2s;
      }

      .password-form input[type="password"]:focus {
        outline: none;
        border-color: var(--color-accent);
        box-shadow: 0 0 0 3px var(--color-accent-light);
      }

      .password-form .password-button {
        width: 100%;
        padding: 14px 24px;
        background: var(--color-accent);
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        font-family: inherit;
        transition: opacity 0.2s;
      }

      .password-form .password-button:hover {
        opacity: 0.9;
      }

      .password-form .form__message {
        color: #e53e3e;
        font-size: 14px;
        margin-top: 8px;
        display: flex;
        align-items: center;
        gap: 6px;
      }

      .password__footer {
        padding: 20px 40px;
        text-align: center;
        border-top: 1px solid rgba(0,0,0,0.08);
        font-size: 13px;
        color: #999;
      }

      .password__footer a {
        color: #666;
      }

      .list-social {
        list-style: none;
        display: flex;
        gap: 16px;
        justify-content: center;
        padding: 0;
        margin: 0 0 12px;
      }

      .list-social__link {
        color: #666;
        transition: color 0.2s;
      }

      .list-social__link:hover {
        color: var(--color-accent);
      }

      .list-social__link svg {
        width: 20px;
        height: 20px;
      }

      @media (max-width: 749px) {
        .password-header {
          padding: 16px 20px;
        }
        .password-main__inner h1 {
          font-size: 24px;
        }
        .password-modal__box {
          padding: 28px;
        }
      }
    </style>

    <script>document.documentElement.className = document.documentElement.className.replace('no-js', 'js');</script>
  </head>

  <body class="password">
    <a class="skip-to-content-link button visually-hidden" href="#MainContent">
      {{ 'accessibility.skip_to_content' | t }}
    </a>

    <!-- Header -->
    <header class="password-header">
      <div>
        {%- if settings.logo != blank -%}
          {{ settings.logo | image_url: width: 240 | image_tag: class: 'password-header__logo', alt: shop.name }}
        {%- else -%}
          <a href="/" class="password-header__heading">{{ shop.name }}</a>
        {%- endif -%}
      </div>
      <button class="password-link" onclick="document.getElementById('passwordModal').hidden = false;">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        {{ 'general.password_page.login_password_button' | t }}
      </button>
    </header>

    <!-- Main Content -->
    <main id="MainContent" class="password-main">
      <div class="password-main__inner">
        {{ content_for_layout }}
      </div>
    </main>

    <!-- Password Modal -->
    <div id="passwordModal" class="password-modal" hidden>
      <div class="password-modal__box">
        <button class="password-modal__close" onclick="document.getElementById('passwordModal').hidden = true;" aria-label="{{ 'accessibility.close' | t }}">&times;</button>
        <h2>{{ 'general.password_page.login_form_heading' | t }}</h2>
        {%- form 'storefront_password', class: 'password-form' -%}
          <div class="field">
            <input
              type="password"
              name="password"
              id="Password"
              autocomplete="current-password"
              placeholder="{{ 'general.password_page.login_form_password_placeholder' | t }}"
              {% if form.errors %}aria-invalid="true"{% endif %}
            >
            {%- if form.errors -%}
              <div class="form__message" role="alert">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                {{ 'general.password_page.login_form_error' | t }}
              </div>
            {%- endif -%}
          </div>
          <button type="submit" name="commit" class="password-button">
            {{ 'general.password_page.login_form_submit' | t }}
          </button>
        {%- endform -%}
      </div>
    </div>

    <!-- Footer -->
    <footer class="password__footer">
      <small>{{ 'general.password_page.admin_link_html' | t }}</small>
    </footer>
  </body>
</html>
