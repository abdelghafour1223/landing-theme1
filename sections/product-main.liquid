<script>
// Inline offer card selection + inline form synchronization
(function() {
  document.addEventListener('DOMContentLoaded', function() {
    var cards = document.querySelectorAll('.offer-inline-card');
    var qtyInput = document.getElementById('orderQty');
    var priceInput = document.getElementById('orderPrice');
    var offerText = document.getElementById('modalOfferText');

    function syncOffer(qty, price, title) {
      if (qtyInput) qtyInput.value = qty;
      if (priceInput) priceInput.value = price;
      if (offerText) offerText.textContent = title + ' — ' + price + ' درهم';
    }

    // Sync initial preselected offer on page load
    var initialActive = document.querySelector('.offer-inline-card--active') || document.querySelector('.offer-inline-card');
    if (initialActive) {
      var initialQty = initialActive.dataset.qty || "1";
      var initialPrice = initialActive.dataset.price || "0";
      var titleElement = initialActive.querySelector('div[style*="font-size: 16px"]');
      var initialTitle = titleElement ? titleElement.textContent.replace(/[\n\r]+/g, ' ').replace(/\s+/g, ' ').trim() : (initialQty + ' قطعة');
      syncOffer(initialQty, initialPrice, initialTitle);
    }

    cards.forEach(function(card) {
      card.addEventListener('click', function() {
        // Update selection visuals
        cards.forEach(function(c) {
          c.style.borderColor = '#e5e5e5';
          c.style.background = '#fff';
          c.style.boxShadow = 'none';
          c.classList.remove('offer-inline-card--active');
        });
        
        var accentColor = '{{ section.settings.accent_color | default: "#cb6387" }}';
        var accentBg = 'linear-gradient(180deg, {{ section.settings.accent_color_light | default: "#fff5f7" }} 0%, #fff 100%)';
        
        card.style.borderColor = accentColor;
        card.style.background = accentBg;
        card.style.boxShadow = '0 4px 16px rgba(203, 99, 135, 0.12)';
        card.classList.add('offer-inline-card--active');

        // Sync clicked card values to the inline form instantly
        var qty = card.dataset.qty;
        var price = card.dataset.price;
        var titleElement = card.querySelector('div[style*="font-size: 16px"]');
        var title = titleElement ? titleElement.textContent.replace(/[\n\r]+/g, ' ').replace(/\s+/g, ' ').trim() : (qty + ' قطعة');
        
        syncOffer(qty, price, title);
      });
    });

    // Make the main CTA button scroll smoothly to the offers section & focus input
    var mainCTA = document.getElementById('ProductSubmitButton-template--28684899876945__main');
    if (mainCTA) {
      mainCTA.type = 'button';
      mainCTA.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        var targetSection = document.querySelector('.offer-bundle-inline');
        if (targetSection) {
          targetSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
          setTimeout(function() {
            var fullName = document.getElementById('fullName');
            if (fullName) fullName.focus();
          }, 800);
        }
      });
    }
  });
})();
</script>

