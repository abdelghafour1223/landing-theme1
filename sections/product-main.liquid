      <div class="shop-image-container shop-square-container">
        {%- if product.media.size > 0 -%}
          {%- for media in product.media -%}
            <img class="shop-main-image {% if forloop.first %}active{% endif %}"
                 src="{{ media | image_url: width: 600, height: 600 }}"
                 srcset="{{ media | image_url: width: 600, height: 600 }} 1x, {{ media | image_url: width: 1200, height: 1200 }} 2x"
                 alt="{{ media.alt | default: product.title | escape }}"
                 loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                 width="600" height="600"
                 data-src="{{ media | image_url: width: 600, height: 600 }}"
                 data-media-id="{{ media.id }}"
                 {% if forloop.first %}fetchpriority="high"{% endif %}>
          {%- endfor -%}
        {%- else -%}
          <img class="shop-main-image active" src="{{ 'product-main.jpg' | asset_url }}" loading="eager" width="600" height="600" fetchpriority="high">
