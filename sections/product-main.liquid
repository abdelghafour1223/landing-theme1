<!-- Visual Variant & Color Swatches -->
{%- if product.has_only_default_variant == false -%}
  <div class="product-variant-swatches" style="margin: 20px 0 10px; direction: rtl; text-align: right;">
    {%- for option in product.options_with_values -%}
      <div class="variant-option-group" style="margin-bottom: 16px;" data-option-index="{{ option.position }}">
        <label style="font-size: 14px; font-weight: 800; color: #121212; display: block; margin-bottom: 8px;">{{ option.name }}</label>
        <div class="swatches-container" style="display: flex; gap: 10px; flex-wrap: wrap;">
          {%- for value in option.values -%}
            {%- assign is_color = false -%}
            {%- assign downcase_name = option.name | downcase -%}
            {%- if downcase_name contains 'color' or downcase_name contains 'لون' -%}
              {%- assign is_color = true -%}
            {%- endif -%}
            
            <button type="button" 
                    class="swatch-button {% if option.selected_value == value %}swatch-active{% endif %}" 
                    data-option-position="{{ option.position }}" 
                    data-value="{{ value | escape }}"
