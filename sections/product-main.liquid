  <script type="application/json" id="VariantJson-{{ section.id }}">
    {{ product.variants | json }}
  </script>

  <script>
  document.addEventListener('DOMContentLoaded', function() {
    var swatchGroups = document.querySelectorAll('.variant-option-group');
    var variantJsonEl = document.getElementById('VariantJson-{{ section.id }}');
    var hiddenVariantInput = document.getElementById('selectedVariantId');
    var formVariantInput = document.querySelector('form input[name="id"]');
    
    if (!variantJsonEl) return;
    
    var variants = JSON.parse(variantJsonEl.textContent);
    
    swatchGroups.forEach(function(group) {
      var buttons = group.querySelectorAll('.swatch-button');
      var position = parseInt(group.dataset.optionIndex);
      
      buttons.forEach(function(btn) {
        btn.addEventListener('click', function() {
          buttons.forEach(function(b) {
            b.style.borderColor = '#e5e5e5';
            b.classList.remove('swatch-active');
          });
          
          var accentColor = '{{ section.settings.accent_color | default: "#cb6387" }}';
          btn.style.borderColor = accentColor;
          btn.classList.add('swatch-active');
          
          updateSelectedVariant();
        });
      });
    });
    
    function updateSelectedVariant() {
      var selectedOptions = {};
      document.querySelectorAll('.variant-option-group').forEach(function(group) {
        var activeBtn = group.querySelector('.swatch-button.swatch-active');
        if (activeBtn) {
          var position = group.dataset.optionIndex;
          selectedOptions['option' + position] = activeBtn.dataset.value;
        }
      });
      
      var matchedVariant = variants.find(function(v) {
        var match = true;
        for (var key in selectedOptions) {
          if (v[key] !== selectedOptions[key]) {
            match = false;
            break;
          }
        }
        return match;
      });
      
      if (matchedVariant) {
        if (hiddenVariantInput) hiddenVariantInput.value = matchedVariant.id;
        if (formVariantInput) formVariantInput.value = matchedVariant.id;
        
        var offerText = document.getElementById('modalOfferText');
        var priceVal = (matchedVariant.price / 100).toFixed(0);
        
        var activeCard = document.querySelector('.offer-inline-card--active');
        if (activeCard && activeCard.dataset.qty === '1') {
          activeCard.dataset.price = priceVal;
          var priceTextEl = activeCard.querySelector('div[style*="font-size: 22px"]');
          if (priceTextEl) priceTextEl.innerHTML = priceVal + ' <small style="font-size: 13px; font-weight: 600;">درهم</small>';
          
          if (offerText) {
            var titleElement = activeCard.querySelector('div[style*="font-size: 16px"]');
            var title = titleElement ? titleElement.textContent.trim() : '1 قطعة';
            offerText.textContent = title + ' — ' + priceVal + ' درهم';
          }
        }
        
        if (matchedVariant.featured_media && matchedVariant.featured_media.id) {
          var thumb = document.querySelector('.shop-thumbnail[data-media-id="' + matchedVariant.featured_media.id + '"]');
          if (thumb) thumb.click();
        }
      }
    }
  });
  </script>
