

<!-- Apply mobile fonts immediately on page load -->


<div class="store-faq-section" style="
  padding-top: 60px;
  padding-bottom: 60px;
  background-color: #ffffff !important;
">
  <div class="store-faq-container" style="
    width: 100%;
    max-width: 1200px;
    padding-left: 15px;
    padding-right: 15px;
    margin: 0 auto;
  ">
    <div class="page-width faq-flex-container center-no-image ">
      <div class="faq-header-column">
        
          <h2 class="store-faq-heading" style="color: #121212 !important; font-size: 36px;">
            {{ section.settings.heading }}
          </h2>
        
        
        
        
        <div class="store-faq" id="store-faq-template--28684899876945__store_faq_Lpd3PW" style="
            width: 100%;
            margin: 0 auto;
          ">
          
            <!-- Single Column Layout (Default) -->
            <div class="faq-container" style="border-radius: 8px;" data-accordion="true">
              {%- for block in section.blocks -%}
                <div class="faq-item" style="border-bottom: 1px solid #E5E5E5 !important;" {{ block.shopify_attributes }}>
                  <div class="faq-question" style="
                    color: #121212 !important;
                    background-color: #ffffff !important;
                  " data-store-faq-listener="true">
                    <span>{{ block.settings.question }}</span>
                    <span class="faq-toggle">+</span>
                  </div>
                  <div class="faq-answer" style="
                    color: #121212 !important;
                    background-color: #ffffff !important;
                    --answer-padding-top: 18px;
                    --answer-padding-bottom: 15px;
                    --answer-padding-left: 20px;
                    --answer-padding-right: 20px;
                  " data-padding-active="0 20px 16px" data-padding-mobile-active="0 12px 10px">
                    <p>{{ block.settings.answer }}</p>
                  </div>
                </div>
              {%- endfor -%}
            </div>
                      <div class="faq-answer" style="
                        color: #121212 !important;
                        background-color: #ffffff !important;
                        --answer-padding-top: 18px;
                        --answer-padding-bottom: 15px;
                        --answer-padding-left: 20px;
                        --answer-padding-right: 20px;
                      " data-padding-active="0 20px 16px" data-padding-mobile-active="0 12px 10px">
                        <p>البطارية كتدوم حتى لـ 2.5 ساعة ديال الاستعمال المستمر (حوالي 4 إلى 5 حصص سحب)، وكتشحن بسرعة بالـ USB-C فتقريباً ساعتين. كتقدري تستعمليها فكل وقت بغيتي بكل سهولة.</p>
                      </div>
                    </div>
                
              
                
                    <div class="faq-item" style="border-bottom: 1px solid #E5E5E5 !important;">
                      <div class="faq-question" style="
                        color: #121212 !important;
                        background-color: #ffffff !important;
                      " data-store-faq-listener="true">
                        <span>واش عملية السحب مريحة ومكتسببش الألم؟</span>
                        <span class="faq-toggle">+</span>
