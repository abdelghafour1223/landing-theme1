[
  {
    "name": "Theme settings",
    "settings": [
      {
        "type": "header",
        "content": "Logo"
      },
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo image"
      },
      {
        "type": "range",
        "id": "logo_width",
        "min": 50,
        "max": 300,
        "step": 10,
        "unit": "px",
        "label": "Custom logo width",
        "default": 120
      },
      {
        "type": "header",
        "content": "Favicon"
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon image",
        "info": "Will be scaled down to 32x32px"
      }
    ]

  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "header",
        "content": "Accent colors"
      },
      {
        "type": "color",
        "id": "colors_accent_1",
        "label": "Accent 1",
        "default": "#121212"
      },
      {
        "type": "color_background",
        "id": "gradient_accent_1",
        "label": "Accent 1 gradient"
      },
      {
        "type": "color",
        "id": "colors_accent_2",
        "label": "Accent 2",
        "default": "#ef4a65"
      },
      {
        "type": "color_background",
        "id": "gradient_accent_2",
        "label": "Accent 2 gradient"
      },
      {
        "type": "header",
        "content": "Text"
      },
      {
        "type": "color",
        "id": "colors_text",
        "label": "Text",
        "default": "#000000"
      },
      {
        "type": "color",
        "id": "colors_outline_button_labels",
        "label": "Outline button labels",
        "default": "#121212"
      },
      {
        "type": "color",
        "id": "colors_solid_button_labels",
        "label": "Solid button labels",
        "default": "#ffffff"
      },
      {
        "type": "header",
        "content": "Backgrounds"
      },
      {
        "type": "color",
        "id": "colors_background_1",
        "label": "Background 1",
        "default": "#fafaf9"
      },
      {
        "type": "color_background",
        "id": "gradient_background_1",
        "label": "Background 1 gradient"
      },
      {
        "type": "color",
        "id": "colors_background_2",
        "label": "Background 2",
        "default": "#f3f3f3"
      },
      {
        "type": "color_background",
        "id": "gradient_background_2",
        "label": "Background 2 gradient"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "header",
        "content": "Headings"
      },
      {
        "type": "font_picker",
        "id": "type_header_font",
        "label": "Font",
        "default": "helvetica_n7"
      },
      {
        "type": "range",
        "id": "heading_scale",
        "min": 100,
        "max": 150,
        "step": 5,
        "unit": "%",
        "label": "Font size scale",
        "default": 100
      },
      {
        "type": "header",
        "content": "Body"
      },
      {
        "type": "font_picker",
        "id": "type_body_font",
        "label": "Font",
        "default": "helvetica_n4"
      },
      {
        "type": "range",
        "id": "body_scale",
        "min": 100,
        "max": 130,
        "step": 5,
        "unit": "%",
        "label": "Font size scale",
        "default": 100
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "page_width",
        "min": 1000,
        "max": 1600,
        "step": 100,
        "unit": "px",
        "label": "Page width",
        "default": 1600
      },
      {
        "type": "range",
        "id": "spacing_sections",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "label": "Section spacing",
        "default": 0
      }
    ]
  },
  {
    "name": "Buttons",
    "settings": [
      {
        "type": "range",
        "id": "buttons_border_thickness",
        "min": 0,
        "max": 12,
        "step": 1,
        "unit": "px",
        "label": "Border thickness",
        "default": 1
      },
      {
        "type": "range",
        "id": "buttons_border_opacity",
        "min": 0,
        "max": 100,
        "step": 5,
        "unit": "%",
        "label": "Border opacity",
        "default": 100
      },
      {
        "type": "range",
        "id": "buttons_radius",
        "min": 0,
        "max": 40,
        "step": 2,
        "unit": "px",
        "label": "Corner radius",
        "default": 40
      },
      {
        "type": "range",
        "id": "buttons_shadow_opacity",
        "min": 0,
        "max": 100,
        "step": 5,
        "unit": "%",
        "label": "Shadow opacity",
        "default": 0
      }
    ]
  },
  {
    "name": "Product cards",
    "settings": [
      {
        "type": "select",
        "id": "card_style",
        "options": [
          {
            "value": "standard",
            "label": "Standard"
          },
          {
            "value": "card",
            "label": "Card"
          }
        ],
        "default": "standard",
        "label": "Style"
      },
      {
        "type": "select",
        "id": "card_text_alignment",
        "options": [
          {
            "value": "left",
            "label": "Left"
          },
          {
            "value": "center",
            "label": "Center"
          },
          {
            "value": "right",
            "label": "Right"
          }
        ],
        "default": "left",
        "label": "Text alignment"
      },
      {
        "type": "range",
        "id": "card_image_padding",
        "min": 0,
        "max": 30,
        "step": 2,
        "unit": "px",
        "label": "Image padding",
        "default": 0
      },
      {
        "type": "range",
        "id": "card_corner_radius",
        "min": 0,
        "max": 40,
        "step": 2,
        "unit": "px",
        "label": "Corner radius",
        "default": 4
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "options": [
          {
            "value": "drawer",
            "label": "Drawer"
          },
          {
            "value": "page",
            "label": "Page"
          },
          {
            "value": "notification",
            "label": "Notification"
          }
        ],
        "default": "drawer",
        "label": "Cart type"
      },
      {
        "type": "checkbox",
        "id": "show_cart_note",
        "default": false,
        "label": "Enable cart note"
      },
      {
        "type": "checkbox",
        "id": "show_vendor",
        "default": false,
        "label": "Show vendor"
      }
    ]
  },
  {
    "name": "Search behavior",
    "settings": [
      {
        "type": "checkbox",
        "id": "predictive_search_enabled",
        "default": true,
        "label": "Enable predictive search"
      },
      {
        "type": "checkbox",
        "id": "predictive_search_show_vendor",
        "default": false,
        "label": "Show vendor in predictive search"
      },
      {
        "type": "checkbox",
        "id": "predictive_search_show_price",
        "default": false,
        "label": "Show price in predictive search"
      }
    ]
  },
